@model List<CarteiraDeMembroDigital.Models.Evento>
@{ Layout = null; }

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ADHEL - Agenda</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        html { background-color: #2d3748; }
        body { width: 100%; max-width: 414px; min-height: 100vh; background-color: #1a202c; margin: 0 auto; position: relative; font-family: 'Montserrat', sans-serif; color: #fff; display: flex; flex-direction: column; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; padding: 20px 25px; background: #0d1326; border-bottom: 2px solid #bba371; }
        .back-btn { color: #bba371; font-size: 22px; text-decoration: none; }
        .content { padding: 25px 20px; flex: 1; }
        
        /* Timeline Items */
        .timeline { position: relative; padding-left: 20px; border-left: 2px solid #bba371; margin-left: 15px; margin-top: 20px; }
        .event-node { position: relative; margin-bottom: 30px; }
        .event-node::before { content: ''; position: absolute; left: -27px; top: 4px; width: 12px; height: 12px; border-radius: 50%; background: #bba371; border: 3px solid #1a202c; }
        
        .event-date { font-weight: 700; font-size: 12px; color: #bba371; text-transform: uppercase; margin-bottom: 5px; display: block; }
        .event-box { background: #fff; color: #2d3748; border-radius: 12px; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.15); }
        .event-title { margin: 0 0 5px 0; font-size: 16px; color: #0d1326; font-weight: 700; }
        .event-desc { font-size: 13px; color: #4a5568; margin: 0 0 10px 0; }
        .event-meta { font-size: 11px; color: #718096; display: flex; gap: 15px; }
        .event-meta i { color: #2c5282; }
    </style>
</head>
<body>
    <div class="top-bar">
        <a href="@Url.Action("Index", "Home")" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>
        <div style="color: #bba371; font-weight: bold;">AGENDA DA IGREJA</div>
        <div style="width: 22px;"></div>
    </div>

    <div class="content">
        <h3 style="margin: 0; font-size: 18px;">Próximos Eventos</h3>
        
        @if (!Model.Any())
        {
            <p style="color: #a0aec0; margin-top: 30px; text-align: center;">Nenhum evento agendado no momento.</p>
        }

        <div class="timeline">
            @foreach (var ev in Model)
            {
                <div class="event-node">
                    <span class="event-date">@ev.DataHora.ToString("dd MMM yyyy - dddd")</span>
                    <div class="event-box">
                        <h4 class="event-title">@ev.Titulo</h4>
                        <p class="event-desc">@ev.Descricao</p>
                        <div class="event-meta">
                            <span><i class="fa-regular fa-clock"></i> @ev.DataHora.ToString("HH:mm")h</span>
                            <span><i class="fa-solid fa-location-dot"></i> @ev.Local</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</body>
</html>