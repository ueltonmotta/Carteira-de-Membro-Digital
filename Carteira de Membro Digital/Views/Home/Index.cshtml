@model CarteiraDeMembroDigital.Models.Usuario

@{
    ViewData["Title"] = "Carteira de Membro Digital";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
    
    <style>
        /* ========================================== */
        /* LAYOUT FLUIDO E RESPONSIVO                 */
        /* ========================================== */
        html { 
            background-color: #2d3748; 
        }
        
        body {
            width: 100%;
            max-width: 414px; 
            min-height: 100vh; 
            background-color: #1a202c; 
            margin: 0 auto; 
            position: relative;
            box-shadow: 0 0 20px rgba(0,0,0,0.5); 
            overflow-x: hidden;
            font-family: 'Montserrat', sans-serif;
            display: flex;
            flex-direction: column;
        }

        /* ========================================== */
        /* TOP BAR E BOTÃO HAMBURGER FIXO À DIREITA   */
        /* ========================================== */
        .top-bar {
            position: absolute; 
            top: 0; 
            left: 0;
            width: 100%;
            display: flex;
            justify-content: space-between; 
            align-items: center;
            padding: 20px 25px; 
            box-sizing: border-box;
            z-index: 1000;
            background-color: transparent; 
        }

        .logo-text { 
            color: #bba371; 
            font-weight: bold; 
            font-size: 18px; 
            letter-spacing: 1px; 
        }

        .hamburger-btn { 
            color: #bba371; 
            font-size: 28px; 
            cursor: pointer; 
            margin-left: auto; 
            padding: 5px;
        }

        /* ========================================== */
        /* SIDEBAR (MENU UNIFICADO FIXO NA TELA)      */
        /* ========================================== */
        .sidebar-menu {
            position: fixed; 
            top: 0; right: -300px;
            width: 280px;
            height: 100vh;
            background-color: #ffffff;
            box-shadow: -5px 0 20px rgba(0,0,0,0.5);
            transition: right 0.3s ease;
            z-index: 2000;
            display: flex;
            flex-direction: column;
        }
        .sidebar-menu.open { right: 0; }
        
        .sidebar-header {
            background-color: #0d1326;
            color: #fff;
            padding: 25px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid #bba371;
        }
        .sidebar-header h3 { margin: 0; font-size: 16px; text-transform: uppercase; }
        .close-btn { font-size: 24px; cursor: pointer; color: #e53e3e; }

        .sidebar-links { padding: 10px 0; overflow-y: auto; }
        .sidebar-links a {
            display: block;
            padding: 16px 20px;
            color: #2d3748;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
        }
        .sidebar-links a:active { background-color: #f7fafc; }
        .sidebar-links a i { width: 30px; color: #2c5282; font-size: 18px; text-align: center; margin-right: 5px; }
        .sidebar-links a.active { color: #2c5282; background-color: #ebf8ff; border-left: 4px solid #2c5282; padding-left: 16px; }
        
        .menu-divider { border: 0; border-top: 1px solid #edf2f7; margin: 5px 20px; }

        .menu-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100vh;
            background: rgba(0,0,0,0.7);
            z-index: 1999;
            display: none;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .menu-overlay.open { display: block; opacity: 1; }

        /* ========================================== */
        /* CONTEÚDO DO CARTÃO                         */
        /* ========================================== */
        .mobile-wrapper {
            flex: 1; 
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .instruction-text { color: #a0aec0; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; }
        
        .card-container { width: 100%; max-width: 320px; aspect-ratio: 1 / 1.6; perspective: 1000px; cursor: pointer; z-index: 5; }
        .card-inner { position: relative; width: 100%; height: 100%; text-align: center; transition: transform 0.8s; transform-style: preserve-3d; }
        .card-container.is-flipped .card-inner { transform: rotateY(180deg); }
        .card-face { position: absolute; width: 100%; height: 100%; -webkit-backface-visibility: hidden; backface-visibility: hidden; border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.3); overflow: hidden; display: flex; flex-direction: column; }
        
        /* Frente do Cartão */
        .card-front { background: #f8fafc; border: 2px solid #bba371; padding: 25px 20px; box-sizing: border-box; justify-content: flex-start; }
        .card-front .header h2 { margin: 0; color: #2c5282; font-size: 22px; font-weight: 800; line-height: 1.2; }
        .card-front .header h2 span { font-size: 14px; font-weight: 600; color: #4a5568; }
        .card-front .header p { margin: 5px 0 0 0; color: #bba371; font-size: 12px; font-weight: 700; letter-spacing: 1.5px; }
        
        .photo-section { margin: 25px auto; width: 130px; height: 130px; border-radius: 12px; border: 3px solid #bba371; overflow: hidden; background: #e2e8f0; }
        .member-photo { width: 100%; height: 100%; object-fit: cover; }
        
        /* Verso do Cartão */
        .card-back { background: #0d1326; color: #e2e8f0; border: 2px solid #bba371; transform: rotateY(180deg); padding: 25px 20px; box-sizing: border-box; }
        .back-header { border-bottom: 1px solid #2d3748; padding-bottom: 15px; margin-bottom: 20px; }
        .back-header h3 { margin: 0; color: #bba371; font-size: 16px; letter-spacing: 1px; }
        .back-details { display: flex; flex-direction: column; gap: 15px; text-align: left; }
        .detail-row { display: flex; flex-direction: column; gap: 3px; }
        .detail-row .label { font-size: 11px; color: #a0aec0; text-transform: uppercase; font-weight: bold; }
        .detail-row .value { font-size: 14px; color: #fff; font-weight: 600; }
    </style>
</head>
<body>

    <div class="top-bar">
        <div class="logo-text">ADHEL</div>
        <i class="fa-solid fa-bars hamburger-btn" onclick="toggleMenu()"></i>
    </div>

    <div class="sidebar-menu" id="sidebarMenu">
        <div class="sidebar-header">
            <h3>Menu</h3>
            <i class="fa-solid fa-xmark close-btn" onclick="toggleMenu()"></i>
        </div>
        <div class="sidebar-links">
            <a href="@Url.Action("Index", "Home")"><i class="fa-solid fa-id-card"></i> Cartão Digital</a>
            <a href="@Url.Action("Anuncios", "Home")"><i class="fa-solid fa-bullhorn"></i> Anúncios e Avisos</a>
            <a href="@Url.Action("Calendario", "Home")"><i class="fa-solid fa-calendar-days"></i> Agenda da Igreja</a>
            
            <hr class="menu-divider">

            <a href="@Url.Action("Membro", "Perfil")"><i class="fa-solid fa-user"></i> Meu Perfil</a>
            <a href="@Url.Action("Editar", "Perfil")"><i class="fa-solid fa-pen-to-square"></i> Editar Dados</a>
            
            <hr class="menu-divider">
            
            <a href="@Url.Action("Configuracoes", "Home")"><i class="fa-solid fa-gear"></i> Configurações</a>
            <a href="@Url.Action("Sobre", "Home")"><i class="fa-solid fa-circle-info"></i> Sobre a Igreja</a>
            <a href="@Url.Action("Suporte", "Home")"><i class="fa-solid fa-headset"></i> Ajuda e Suporte</a>
            <a href="@Url.Action("Termos", "Home")"><i class="fa-solid fa-file-contract"></i> Termos de Uso</a>
            
            <hr class="menu-divider">
            
            <a href="@Url.Action("Login", "Conta")" style="color: #e53e3e;"><i class="fa-solid fa-right-from-bracket" style="color: #e53e3e;"></i> Sair da Conta</a>
        </div>
    </div>
    
    <div class="menu-overlay" id="menuOverlay" onclick="toggleMenu()"></div>

    <div class="mobile-wrapper">
        <p class="instruction-text">Toque no cartão para virar</p>

        <div class="card-container" onclick="flipCard()">
            <div class="card-inner" id="memberCard">
                
                <div class="card-face card-front">
                    <div class="header">
                        <h2>ADHEL<br><span>Assembleia de Deus em Helianópolis</span></h2>
                        <p>CARTEIRA DE MEMBRO</p>
                    </div>
                    <div class="photo-section">
                        <img src="@(string.IsNullOrEmpty(Model.FotoPerfil) ? "/images/foto-membro.jpg" : Model.FotoPerfil)" alt="Foto" class="member-photo" />
                    </div>
                    
                    <div class="main-info">
                        <h3 style="text-transform: uppercase; margin: 0 0 5px 0; color: #0d1326; font-size: 22px;">@Model.Nome</h3>
                        <p class="role" style="text-transform: uppercase; margin: 0; color: #bba371; font-weight: bold; font-size: 14px; letter-spacing: 1px;">@(Model.Cargo ?? "Membro")</p>
                    </div>
                    
                    <div style="text-align: center; margin-top: 25px;">
                        <div style="display: inline-block; background: #fff; padding: 8px; border-radius: 8px; margin-bottom: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                            <div id="qrcode-container" style="min-width: 100px; min-height: 100px;"></div>
                        </div>

                        <div style="color: #4a5568; font-size: 13px; font-weight: 600; display: flex; justify-content: center; gap: 20px;">
                            <span>ID: ADHEL-@Model.Id.ToString("D4")</span>
                            <span>VAL: @(Model.DataValidade.ToString("MM/yyyy"))</span>
                        </div>
                    </div>
                </div>

                <div class="card-face card-back">
                    <div class="back-header">
                        <h3>DADOS DO MEMBRO</h3>
                    </div>
                    <div class="back-details">
                        <div class="detail-row"><span class="label">Nome:</span><span class="value">@Model.Nome</span></div>
                        <div class="detail-row"><span class="label">Cargo:</span><span class="value">@(Model.Cargo ?? "Membro")</span></div>
                        <div class="detail-row"><span class="label">Estado Civil:</span><span class="value">@(Model.EstadoCivil ?? "Não informado")</span></div>
                        <div class="detail-row"><span class="label">RG:</span><span class="value">@(Model.RG ?? "Não informado")</span></div>
                        <div class="detail-row"><span class="label">CPF:</span><span class="value">@(Model.CPF ?? "Não informado")</span></div>
                        <div class="detail-row"><span class="label">Membro desde:</span><span class="value">@(Model.DataEmissao.ToString("yyyy") ?? "2024")</span></div>
                    </div>
                </div>

            </div>
        </div>

       @if (TempData["ErroCheckIn"] != null)
        {
            <div style="background: #fed7d7; color: #9b2c2c; padding: 12px; border-radius: 8px; margin-top: 20px; font-size: 13px; text-align: center; width: 100%; max-width: 320px;"><i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErroCheckIn"]</div>
        }
        @if (TempData["SucessoCheckIn"] != null)
        {
            <div style="background: #c6f6d5; color: #22543d; padding: 12px; border-radius: 8px; margin-top: 20px; font-size: 13px; text-align: center; width: 100%; max-width: 320px;"><i class="fa-solid fa-circle-check"></i> @TempData["SucessoCheckIn"]</div>
        }

        @if (ViewBag.MostrarBotaoGps == true)
        {
            <button onclick="solicitarLocalizacao()" style="background-color: #0d1326; color: #bba371; border: 2px solid #bba371; border-radius: 30px; padding: 15px 25px; font-weight: bold; font-size: 14px; margin-top: 25px; cursor: pointer; text-transform: uppercase; display: flex; align-items: center; gap: 10px; width: 100%; max-width: 320px; justify-content: center; z-index: 10;">
                <i class="fa-solid fa-location-dot"></i> Assinar Lista da Santa Ceia
            </button>

            <form id="formCheckIn" asp-action="CheckInSantaCeia" method="post" style="display: none;">
                <input type="hidden" name="eventoId" value="@ViewBag.EventoId" />
                <input type="hidden" id="latitudeInput" name="latitude" />
                <input type="hidden" id="longitudeInput" name="longitude" />
            </form>
        }

        @if (ViewBag.PedirJustificativa == true)
        {
            <div style="background: #fff; padding: 20px; border-radius: 12px; margin-top: 25px; width: 100%; max-width: 320px; box-sizing: border-box; border-left: 4px solid #dd6b20;">
                <h4 style="margin: 0 0 10px 0; color: #dd6b20; font-size: 15px;"><i class="fa-solid fa-clock-rotate-left"></i> Justificativa de Ausência</h4>
                <p style="font-size: 12px; color: #4a5568; margin-top: 0;">Sentimos sua falta na Santa Ceia de @ViewBag.DataFalta. Por favor, justifique o motivo no prazo de 48h.</p>
                
                <form asp-action="EnviarJustificativa" method="post">
                    <input type="hidden" name="eventoId" value="@ViewBag.EventoFaltaId" />
                    <textarea name="motivo" rows="2" placeholder="Motivo da ausência..." required style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #cbd5e0; font-family: inherit; font-size: 13px; box-sizing: border-box; margin-bottom: 10px;"></textarea>
                    <button type="submit" style="width: 100%; background: #0d1326; color: white; border: none; padding: 10px; border-radius: 6px; font-weight: bold; cursor: pointer;">Enviar à Secretaria</button>
                </form>
            </div>
        }
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script>
        function toggleMenu() {
            document.getElementById("sidebarMenu").classList.toggle("open");
            document.getElementById("menuOverlay").classList.toggle("open");
        }

        function flipCard() {
            document.getElementById('memberCard').classList.toggle('is-flipped');
        }

        // LÓGICA DE GEOLOCALIZAÇÃO
        function solicitarLocalizacao() {
            if (navigator.geolocation) {
                alert("A verificar a sua localização. Por favor, aguarde e permita o acesso ao GPS se for solicitado...");
                navigator.geolocation.getCurrentPosition(enviarParaServidor, mostrarErro, {
                    enableHighAccuracy: true,
                    timeout: 10000,
                    maximumAge: 0
                });
            } else {
                alert("O seu navegador não suporta geolocalização.");
            }
        }

        function enviarParaServidor(posicao) {
            document.getElementById('latitudeInput').value = posicao.coords.latitude.toString().replace('.', ',');
            document.getElementById('longitudeInput').value = posicao.coords.longitude.toString().replace('.', ',');
            document.getElementById('formCheckIn').submit();
        }

        function mostrarErro(erro) {
            switch(erro.code) {
                case erro.PERMISSION_DENIED:
                    alert("Você negou o acesso ao GPS. Não é possível assinar a lista sem a localização.");
                    break;
                case erro.POSITION_UNAVAILABLE:
                    alert("As informações de localização não estão disponíveis neste momento.");
                    break;
                case erro.TIMEOUT:
                    alert("O pedido para obter a localização demorou demasiado tempo.");
                    break;
            }
        }

        window.onload = function () {
            var estaExpirado = "@(ViewBag.CartaoExpirado == true ? "true" : "false")" === "true";
            var statusAtual = "@(ViewBag.StatusExibicao ?? "ATIVO")";
            var dataValidadeStr = "@Model.DataValidade.ToString("dd/MM/yyyy")";
            var nomeMembro = "@(Model.Nome ?? "Membro")";
            var idMembro = "ADHEL-@Model.Id.ToString("D4")";

            var dadosValidacao = estaExpirado 
                ? "[ALERTA: CARTAO EXPIRADO]\nNome: " + nomeMembro + "\nID: " + idMembro + "\nValidade: " + dataValidadeStr
                : "[MEMBRO VALIDADO]\nNome: " + nomeMembro + "\nID: " + idMembro + "\nStatus: " + statusAtual + "\nValidade: " + dataValidadeStr;

            var qrContainer = document.getElementById("qrcode-container");
            if (qrContainer) {
                qrContainer.innerHTML = ""; 
                new QRCode(qrContainer, {
                    text: dadosValidacao,
                    width: 100, // Aumentado para preencher melhor o espaço central
                    height: 100,         
                    colorDark: estaExpirado ? "#e53e3e" : "#0d1326", 
                    colorLight: "#ffffff", 
                    correctLevel: QRCode.CorrectLevel.L
                });
            }
        };
    </script>
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/js/site.js"></script>
</body>
</html>