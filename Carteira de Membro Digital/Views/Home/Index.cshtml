@{
    ViewData["Title"] = "Carteira de Membro Digital";
    Layout = null; /* Remove o layout padrão para focar na tela do celular */
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="mobile-wrapper">
        <p class="instruction-text">Toque no cartão para virar</p>

        <div class="card-container" onclick="flipCard()">

            <div class="card-inner" id="memberCard">

                <div class="card-face card-front">
                    <div class="header">
                        <h2>ADHEL<br><span>Assembleia de Deus em Helianópolis</span></h2>
                        <p>CARTEIRA DE MEMBRO</p>
                    </div>

                    <div class="photo-section">
                        <img src="@(string.IsNullOrEmpty(Model.FotoPerfil) ? "/images/foto-membro.jpg" : Model.FotoPerfil)" alt="Foto do Membro" class="member-photo" />
                    </div>

                    <div class="main-info">
                        <h3>ANA SILVA</h3>
                        <p class="role">MEMBRO ATIVO</p>
                    </div>

                    <div class="footer-front">
                        <div class="ids">
                            <p><strong>ID:</strong> GC-345.678.910</p>
                            <p><strong>VAL:</strong> 12/2026</p>
                        </div>
                        <img src="~/images/qr-code.png" alt="QR Code" class="qr-small" />
                    </div>
                </div>

                <div class="card-face card-back">
                    <div class="back-header">
                        <h3>DADOS DO MEMBRO</h3>
                    </div>

                    <div class="back-details">
                        <div class="detail-row">
                            <span class="label">Nome Completo:</span>
                            <span class="value">Ana Carolina da Silva</span>
                        </div>
                        <div class="detail-row">
                            <span class="label">Cargo:</span>
                            <span class="value">Membro Ativo</span>
                        </div>
                        <div class="detail-row">
                            <span class="label">Estado Civil:</span>
                            <span class="value">Solteira</span>
                        </div>
                        <div class="detail-row">
                            <span class="label">RG:</span>
                            <span class="value">12.345.678-9</span>
                        </div>
                        <div class="detail-row">
                            <span class="label">CPF:</span>
                            <span class="value">123.456.789-00</span>
                        </div>
                        <div class="detail-row">
                            <span class="label">Data de Batismo:</span>
                            <span class="value">15/04/2018</span>
                        </div>
                    </div>

                    <div class="signature-section">
                        <img src="~/images/assinatura-pastor.png" alt="Assinatura do Pastor" class="signature-img" />
                        <div class="signature-line"></div>
                        <p class="signature-name">Pr. João Marcos</p>
                        <p class="signature-title">Pastor Presidente</p>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="mobile-nav">
        <a href="@Url.Action("Index", "Home")" class="nav-item active">
            <i class="fa-solid fa-id-card"></i>
            <span>Cartão</span>
        </a>

        <a href="@Url.Action("Membro", "Perfil")" class="nav-item">
            <i class="fa-solid fa-user"></i>
            <span>Perfil</span>
        </a>

        <a href="@Url.Action("Editar", "Perfil")" class="nav-item">
            <i class="fa-solid fa-pen-to-square"></i>
            <span>Editar</span>
        </a>

        <a href="@Url.Action("Login", "Conta")" class="nav-item text-danger">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Sair</span>
        </a>
    </div>

    <style>
            /* Adiciona um espaço extra no fim da página para o menu não tampar o conteúdo */
            body {
                padding-bottom: 80px !important;
            }

            .mobile-nav {
                position: fixed;
                bottom: 0;
                left: 0;
                width: 100%;
                background-color: #ffffff;
                display: flex;
                justify-content: space-around;
                align-items: center;
                padding: 12px 0 15px 0;
                box-shadow: 0 -5px 20px rgba(0,0,0,0.15);
                z-index: 1000;
                border-top-left-radius: 25px;
                border-top-right-radius: 25px;
            }

            .nav-item {
                display: flex;
                flex-direction: column;
                align-items: center;
                text-decoration: none;
                color: #718096; /* Cinza padrão */
                font-size: 11px;
                font-weight: 700;
                transition: all 0.3s ease;
            }

                .nav-item i {
                    font-size: 22px;
                    margin-bottom: 4px;
                }

                /* Cor de quando o menu está selecionado (Dourado ADHEL) */
                .nav-item.active {
                    color: #bba371;
                    transform: translateY(-3px); /* Dá um leve saltinho para cima */
                }

                /* Cor do botão de sair (Vermelho) */
                .nav-item.text-danger {
                    color: #e53e3e;
                }

                /* Efeito de clique */
                .nav-item:active {
                    transform: scale(0.9);
                }
    </style>

    <script>
            function flipCard() {
                const card = document.getElementById('memberCard');
                card.classList.toggle('is-flipped');
            }
    </script>
</body>
</html>