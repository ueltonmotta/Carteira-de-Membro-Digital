@{
    ViewData["Title"] = "Configurações";
    Layout = null; 
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        html { background-color: #e2e8f0; }
        body { width: 100%; max-width: 414px; margin: 0 auto; background-color: #f8fafc; min-height: 100vh; position: relative; box-shadow: 0 0 30px rgba(0,0,0,0.2); font-family: 'Montserrat', sans-serif; overflow-x: hidden; }
        .top-bar { position: sticky; top: 0; left: 0; width: 100%; background-color: #0d1326; display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; box-sizing: border-box; border-bottom: 2px solid #bba371; z-index: 100; }
        .back-btn { color: #bba371; font-size: 20px; text-decoration: none; }
        .page-title { color: #fff; font-weight: bold; font-size: 16px; letter-spacing: 1px; text-transform: uppercase; }
        .spacer { width: 20px; }
        .content-area { padding: 25px 20px; color: #2d3748; }
        
        .config-group { background: #fff; border-radius: 12px; border: 1px solid #e2e8f0; margin-bottom: 20px; overflow: hidden; }
        .config-item { display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; border-bottom: 1px solid #edf2f7; font-size: 14px; font-weight: 600; }
        .config-item:last-child { border-bottom: none; }
        .config-item i { color: #2c5282; margin-right: 10px; width: 20px; }
        
        /* Switch Toggle Estilizado */
        .switch { position: relative; display: inline-block; width: 44px; height: 24px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #cbd5e0; transition: .3s; border-radius: 24px; }
        .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .3s; border-radius: 50%; }
        input:checked + .slider { background-color: #2c5282; }
        input:checked + .slider:before { transform: translateX(20px); }

        /* ========================================== */
        /* CORES DO MODO ESCURO                       */
        /* ========================================== */
        body.dark-mode { background-color: #0d1326; }
        body.dark-mode .content-area { color: #e2e8f0; }
        body.dark-mode .config-group { background: #1a202c; border-color: #2d3748; }
        body.dark-mode .config-item { border-bottom-color: #2d3748; color: #e2e8f0; }
        body.dark-mode .config-item i.fa-chevron-right { color: #4a5568 !important; }
    </style>
</head>
<body>

    <div class="top-bar">
        <a href="@Url.Action("Index", "Home")" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>
        <div class="page-title">Configurações</div>
        <div class="spacer"></div>
    </div>

    <div class="content-area">
        <div class="config-group">
            <div class="config-item">
                <div><i class="fa-solid fa-bell"></i> Notificações Push</div>
                <label class="switch">
                    <input type="checkbox" checked>
                    <span class="slider"></span>
                </label>
            </div>
            <div class="config-item">
                <div><i class="fa-solid fa-moon"></i> Modo Escuro</div>
                <label class="switch">
                    <input type="checkbox" id="darkModeToggle">
                    <span class="slider"></span>
                </label>
            </div>
        </div>

        <div class="config-group">
            <div class="config-item" style="cursor: pointer;" onclick="alert('Funcionalidade em desenvolvimento')">
                <div><i class="fa-solid fa-lock"></i> Alterar Palavra-passe</div>
                <i class="fa-solid fa-chevron-right" style="color: #cbd5e0;"></i>
            </div>
            <div class="config-item" style="cursor: pointer;" onclick="alert('Funcionalidade em desenvolvimento')">
                <div><i class="fa-solid fa-shield-halved"></i> Privacidade de Dados</div>
                <i class="fa-solid fa-chevron-right" style="color: #cbd5e0;"></i>
            </div>
        </div>
    </div>

    <script>
        const darkModeToggle = document.getElementById('darkModeToggle');
        const body = document.body;

        // 1. Quando a página carrega, verifica se o utilizador já tinha escolhido o modo escuro antes
        if (localStorage.getItem('theme') === 'dark') {
            body.classList.add('dark-mode');
            darkModeToggle.checked = true; // Deixa a chavinha ligada
        }

        // 2. Quando o utilizador clica na chavinha
        darkModeToggle.addEventListener('change', function() {
            if (this.checked) {
                // Ativa o modo escuro e salva na memória
                body.classList.add('dark-mode');
                localStorage.setItem('theme', 'dark');
            } else {
                // Desativa o modo escuro e salva na memória
                body.classList.remove('dark-mode');
                localStorage.setItem('theme', 'light');
            }
        });
    </script>

</body>
</html>