@{
    ViewData["Title"] = "Sobre a Igreja";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* Força a dimensão de celular igual à tela principal */
        html { background-color: #e2e8f0; }
        body { width: 100%; max-width: 414px; margin: 0 auto; background-color: #f8fafc; min-height: 100vh; position: relative; box-shadow: 0 0 30px rgba(0,0,0,0.2); font-family: 'Montserrat', sans-serif; overflow-x: hidden; }
        
        /* Top Bar com botão de Voltar */
        .top-bar { position: sticky; top: 0; left: 0; width: 100%; background-color: #0d1326; display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; box-sizing: border-box; border-bottom: 2px solid #bba371; z-index: 100; }
        .back-btn { color: #bba371; font-size: 20px; text-decoration: none; }
        .page-title { color: #fff; font-weight: bold; font-size: 16px; letter-spacing: 1px; text-transform: uppercase; }
        .spacer { width: 20px; } /* Mantém o título centralizado */

        /* Área de Conteúdo */
        .content-area { padding: 30px 20px; color: #2d3748; line-height: 1.6; }
        .content-area h2 { color: #0d1326; margin-top: 0; }
        .content-area p { font-size: 14px; margin-bottom: 20px; }
    </style>
</head>
<body>

    <div class="top-bar">
        <a href="@Url.Action("Index", "Home")" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>
        <div class="page-title">Sobre Nós</div>
        <div class="spacer"></div>
    </div>

    <div class="content-area">
        <h2>ADHEL</h2>
        <p>A Assembleia de Deus em Helianópolis é um lugar de adoração, comunhão e ensino da Palavra de Deus.</p>
        <p>Nossa missão é levar o amor de Cristo a todas as famílias e formar discípulos através dos ensinamentos bíblicos.</p>
        
        <div style="background: #fff; padding: 15px; border-radius: 10px; border: 1px solid #e2e8f0; margin-top: 30px;">
            <strong><i class="fa-solid fa-location-dot" style="color: #2c5282;"></i> Endereço:</strong><br>
            Rua Principal, 123 - Helianópolis
        </div>
    </div>

</body>
</html>