@{ Layout = null; }
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sobre a ADHEL</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        html { background-color: #2d3748; }
        body { width: 100%; max-width: 414px; min-height: 100vh; background-color: #1a202c; margin: 0 auto; font-family: 'Montserrat', sans-serif; color: #fff; display: flex; flex-direction: column; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; padding: 20px 25px; background: #0d1326; border-bottom: 2px solid #bba371; }
        .back-btn { color: #bba371; font-size: 22px; text-decoration: none; }
        .content { padding: 30px 20px; flex: 1; text-align: center; }
        .logo-box { background: #0d1326; width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; border: 3px solid #bba371; font-size: 30px; color: #bba371; font-weight: bold; }
        .info-text { color: #a0aec0; font-size: 14px; line-height: 1.6; text-align: left; background: #2d3748; padding: 20px; border-radius: 12px; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="top-bar">
        <a href="@Url.Action("Index", "Home")" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>
        <div style="color: #bba371; font-weight: bold; font-size: 15px;">SOBRE A IGREJA</div>
        <div style="width: 22px;"></div>
    </div>
    <div class="content">
        <div class="logo-box">ADHEL</div>
        <h2 style="margin: 0 0 5px 0;">Assembleia de Deus</h2>
        <p style="color: #bba371; margin: 0 0 20px 0; font-size: 14px;">em Helianópolis</p>
        
        <div class="info-text">
            <p><strong>Missão:</strong> Levar a palavra de Deus, acolher pessoas e transformar vidas através do Evangelho de Cristo.</p>
            <p><strong>Visão:</strong> Ser uma igreja relevante na nossa comunidade, focada no amor ao próximo e no crescimento espiritual.</p>
            <p style="margin-bottom: 0;"><strong>Fundação:</strong> Uma igreja firmada na Rocha, caminhando junta em fé e comunhão.</p>
        </div>
    </div>
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/js/site.js"></script>
</body>
</html>