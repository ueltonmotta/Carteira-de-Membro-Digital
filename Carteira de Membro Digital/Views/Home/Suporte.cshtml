@{
    ViewData["Title"] = "Ajuda e Suporte";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        html { background-color: #e2e8f0; }
        body { width: 100%; max-width: 414px; margin: 0 auto; background-color: #f8fafc; min-height: 100vh; position: relative; box-shadow: 0 0 30px rgba(0,0,0,0.2); font-family: 'Montserrat', sans-serif; overflow-x: hidden; }
        .top-bar { position: sticky; top: 0; left: 0; width: 100%; background-color: #0d1326; display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; box-sizing: border-box; border-bottom: 2px solid #bba371; z-index: 100; }
        .back-btn { color: #bba371; font-size: 20px; text-decoration: none; }
        .page-title { color: #fff; font-weight: bold; font-size: 16px; letter-spacing: 1px; text-transform: uppercase; }
        .spacer { width: 20px; }
        .content-area { padding: 30px 20px; color: #2d3748; }
        .content-area h2 { color: #0d1326; margin-top: 0; font-size: 20px; }
        
        .support-card { background: #fff; border-radius: 12px; padding: 20px; border: 1px solid #e2e8f0; margin-bottom: 20px; }
        .support-btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; background: #25d366; color: white; border: none; padding: 14px; border-radius: 10px; font-size: 15px; font-weight: bold; cursor: pointer; text-decoration: none; box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3); margin-top: 15px; }
        .support-btn.email { background: #2c5282; box-shadow: 0 4px 12px rgba(44, 82, 130, 0.3); }
    </style>
</head>
<body>

    <div class="top-bar">
        <a href="@Url.Action("Index", "Home")" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>
        <div class="page-title">Suporte</div>
        <div class="spacer"></div>
    </div>

    <div class="content-area">
        <h2>Precisa de Ajuda?</h2>
        <p style="font-size: 14px; margin-bottom: 25px;">Se tiver problemas com a sua credencial digital, erro de dados ou dificuldades de acesso, entre em contacto com a nossa equipa de suporte da Secretaria.</p>
        
        <div class="support-card">
            <h4 style="margin: 0 0 10px 0; color: #0d1326;"><i class="fa-brands fa-whatsapp" style="color: #25d366;"></i> Suporte via WhatsApp</h4>
            <p style="margin: 0; font-size: 13px; color: #718096;">Atendimento rápido de Segunda a Sexta, das 9h às 18h.</p>
            <a href="https://wa.me/5521983158669" target="_blank" class="support-btn">
                Falar no WhatsApp
            </a>
        </div>

        <div class="support-card">
            <h4 style="margin: 0 0 10px 0; color: #0d1326;"><i class="fa-solid fa-envelope" style="color: #2c5282;"></i> Suporte via E-mail</h4>
            <p style="margin: 0; font-size: 13px; color: #718096;">Envie os seus prints e dados para análise técnica.</p>
            <a href="mailto:secretaria@adhel.com" class="support-btn email">
                Enviar E-mail
            </a>
        </div>
    </div>

</body>
</html>