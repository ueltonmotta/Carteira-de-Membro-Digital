@{ Layout = null; }
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ajuda e Suporte</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        html { background-color: #2d3748; }
        body { width: 100%; max-width: 414px; min-height: 100vh; background-color: #1a202c; margin: 0 auto; font-family: 'Montserrat', sans-serif; color: #fff; display: flex; flex-direction: column; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; padding: 20px 25px; background: #0d1326; border-bottom: 2px solid #bba371; }
        .back-btn { color: #bba371; font-size: 22px; text-decoration: none; }
        .content { padding: 30px 20px; flex: 1; }
        .contact-card { background: #fff; color: #2d3748; padding: 20px; border-radius: 12px; display: flex; align-items: center; gap: 15px; text-decoration: none; margin-bottom: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .contact-card i { font-size: 24px; color: #bba371; width: 30px; text-align: center; }
        .contact-card h4 { margin: 0 0 5px 0; font-size: 15px; }
        .contact-card p { margin: 0; font-size: 12px; color: #718096; }
    </style>
</head>
<body>
    <div class="top-bar">
        <a href="@Url.Action("Index", "Home")" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>
        <div style="color: #bba371; font-weight: bold; font-size: 15px;">SUPORTE</div>
        <div style="width: 22px;"></div>
    </div>
    <div class="content">
        <h3 style="margin-top: 0;">Como podemos ajudar?</h3>
        <p style="color: #a0aec0; font-size: 14px; margin-bottom: 30px;">Se tiver problemas com o acesso à carteirinha ou precisar atualizar algum documento, entre em contacto com a secretaria.</p>
        
        <a href="https://wa.me/5500000000000" class="contact-card" target="_blank">
            <i class="fa-brands fa-whatsapp" style="color: #25D366;"></i>
            <div>
                <h4>WhatsApp da Secretaria</h4>
                <p>Resposta em horário comercial</p>
            </div>
        </a>

        <a href="mailto:secretaria@adhel.com" class="contact-card">
            <i class="fa-solid fa-envelope"></i>
            <div>
                <h4>E-mail</h4>
                <p>secretaria@adhel.com</p>
            </div>
        </a>
    </div>
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/js/site.js"></script>
</body>
</html>