@{
    // Isto desliga o menu superior e o rodapé padrão, deixando a tela limpa
    Layout = null; 
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Criar Conta - ADHEL</title>
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* TEMA ESCURO (DARK MODE) */
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0d1326; /* Fundo principal escuro */
            color: #e2e8f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .cadastro-card {
            background-color: #1a2544; /* Fundo do formulário (um pouco mais claro) */
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 450px;
            box-sizing: border-box;
            margin: 20px;
            border-top: 4px solid #bba371; /* Linha dourada no topo */
        }

        .header-text { text-align: center; margin-bottom: 30px; }
        .header-text h2 { margin: 0; color: #ffffff; font-size: 24px; }
        .header-text p { color: #a0aec0; font-size: 14px; margin-top: 8px; }

        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-weight: 600; color: #cbd5e0; margin-bottom: 6px; font-size: 13px; }
        
        .form-control {
            width: 100%; padding: 14px;
            background-color: #0d1326; border: 1px solid #2d3748;
            color: #ffffff; border-radius: 8px;
            box-sizing: border-box; font-size: 14px; font-family: inherit;
            transition: border-color 0.3s;
        }
        .form-control:focus { outline: none; border-color: #bba371; }
        .form-control::placeholder { color: #4a5568; }

        /* Estilo específico para o campo de código secreto */
        .input-secreto { border: 1px solid #e53e3e; background-color: #2d1818; }
        .input-secreto:focus { border-color: #fc8181; }

        .btn-submit {
            width: 100%; background-color: #bba371; color: #0d1326;
            border: none; padding: 15px; border-radius: 8px;
            font-size: 15px; font-weight: bold; cursor: pointer;
            transition: background 0.3s; margin-top: 10px;
        }
        .btn-submit:hover { background-color: #a08c5b; }

        .erro-box {
            background-color: rgba(229, 62, 62, 0.1); border: 1px solid #e53e3e;
            color: #fc8181; padding: 12px; border-radius: 8px;
            margin-bottom: 20px; font-size: 13px; font-weight: 600; text-align: center;
        }

        .login-link {
            display: block; text-align: center; margin-top: 25px;
            color: #a0aec0; text-decoration: none; font-size: 13px; transition: color 0.3s;
        }
        .login-link:hover { color: #bba371; }
    </style>
</head>
<body>

    <div class="cadastro-card">
        <div class="header-text">
            <h2>Criar Nova Conta</h2>
            <p>Preencha os dados abaixo para aceder à ADHEL.</p>
        </div>

        @if (ViewBag.Erro != null)
        {
            <div class="erro-box"><i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Erro</div>
        }
        @if (ViewBag.ErroSenha != null)
        {
            <div class="erro-box"><i class="fa-solid fa-key"></i> @ViewBag.ErroSenha</div>
        }

        <form asp-controller="Conta" asp-action="RealizarCadastro" method="post">
            
            <div class="form-group">
                <label>Nome Completo</label>
                <input type="text" name="Nome" class="form-control" placeholder="Seu nome completo" required />
            </div>

            <div class="form-group">
                <label>E-mail</label>
                <input type="email" name="Email" class="form-control" placeholder="exemplo@email.com" required />
            </div>

            <div style="display: flex; gap: 15px;">
                <div class="form-group" style="flex: 1;">
                    <label>CPF</label>
                    <input type="text" name="CPF" class="form-control" placeholder="Apenas números" required />
                </div>
                <div class="form-group" style="flex: 1;">
                    <label>RG</label>
                    <input type="text" name="RG" class="form-control" placeholder="Apenas números" required />
                </div>
            </div>

            <div class="form-group">
                <label>Tipo de Conta / Perfil</label>
                <select name="Perfil" id="perfilSelect" class="form-control" onchange="toggleCodigoSeguranca()" required>
                    <option value="Membro">Membro da Igreja</option>
                    <option value="Secretaria">Secretaria</option>
                    <option value="Pastor Presidente">Pastor Presidente</option>
                </select>
            </div>

            <div id="boxCodigoSeguranca" class="form-group" style="display: none;">
                <label style="color: #fc8181;"><i class="fa-solid fa-lock"></i> Código de Liberação Admin</label>
                <input type="password" name="codigoSeguranca" class="form-control input-secreto" placeholder="Digite o código secreto da igreja" />
            </div>

            <div class="form-group">
                <label>Senha de Acesso (6 dígitos)</label>
                <input type="password" name="Senha" class="form-control" placeholder="Crie uma senha numérica" required />
            </div>

            <div class="form-group" style="margin-bottom: 25px;">
                <label>Confirmar Senha</label>
                <input type="password" name="confirmarSenha" class="form-control" placeholder="Repita a senha numérica" required />
            </div>

            <button type="submit" class="btn-submit">Criar Minha Conta</button>
            
            <a href="@Url.Action("Login")" class="login-link">Já tenho uma conta. <strong>Fazer Login</strong></a>
        </form>
    </div>

    <script>
        function toggleCodigoSeguranca() {
            var perfil = document.getElementById("perfilSelect").value;
            var boxCodigo = document.getElementById("boxCodigoSeguranca");
            
            if (perfil === "Secretaria" || perfil === "Pastor Presidente") {
                boxCodigo.style.display = "block";
            } else {
                boxCodigo.style.display = "none";
            }
        }
    </script>
</body>
</html>