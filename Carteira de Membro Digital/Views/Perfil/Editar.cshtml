@{
    ViewData["Title"] = "Editar Perfil";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body style="background-color: #1a202c; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; font-family: 'Montserrat', sans-serif;">

    <div style="width: 100%; max-width: 400px; padding: 20px;">
        <div style="background: #fff; border-radius: 20px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">

            <h2 style="color: #2c5282; text-align: center; margin-top: 0; margin-bottom: 25px;">Atualizar Dados</h2>

            <form asp-controller="Perfil" asp-action="SalvarEdicao" method="post" enctype="multipart/form-data">

                <input type="hidden" name="Id" value="@Model.Id" />

                <div style="margin-bottom: 20px; text-align: center;">

                    <img src="@(string.IsNullOrEmpty(Model.FotoPerfil) ? "/images/foto-membro.jpg" : Model.FotoPerfil)"
                         style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 3px solid #bba371; margin-bottom: 10px;" />

                    <label style="display: block; color: #4a5568; font-size: 13px; font-weight: bold; margin-bottom: 5px;">Alterar Foto de Perfil</label>

                    <input type="file" name="novaFoto" accept="image/*" style="width: 100%; padding: 10px; font-size: 13px; background: #f8fafc; border: 1px solid #cbd5e0; border-radius: 8px;" />
                </div>

                <div style="margin-bottom: 15px;">
                    <label style="display: block; color: #4a5568; font-size: 13px; font-weight: bold; margin-bottom: 5px;">Nome Completo</label>
                    <input type="text" name="Nome" value="@Model.Nome" style="width: 100%; padding: 12px; border: 1px solid #cbd5e0; border-radius: 10px;" required />
                </div>
            </form>

        </div>
    </div>

</body>
</html>