<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Painel Administrativo - ADHEL</title>
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8fafc;
            color: #2d3748;
        }

        /* Estrutura Principal (Computador) */
        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* BARRA LATERAL ESCURA */
        .sidebar {
            width: 260px;
            background-color: #0d1326;
            color: white;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            border-right: 4px solid #bba371;
            transition: all 0.3s ease;
        }

        .sidebar-header {
            padding: 30px 20px;
            text-align: center;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .sidebar-header h2 {
            margin: 0;
            color: #bba371;
            font-size: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
            flex: 1;
        }

        /* Botão Hamburger (Escondido no PC) */
        .mobile-toggle {
            display: none;
            font-size: 24px;
            color: #bba371;
            cursor: pointer;
        }

        /* Links do Menu */
        .sidebar-menu {
            display: flex;
            flex-direction: column;
            gap: 5px;
            padding: 0 15px;
        }

        .sidebar-menu a {
            color: #cbd5e0;
            text-decoration: none;
            padding: 15px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            transition: background 0.3s, color 0.3s;
        }

        .sidebar-menu a:hover {
            background-color: #1a2544;
            color: #bba371;
        }

        .sidebar-menu a i { width: 20px; text-align: center; font-size: 18px; }
        
        .btn-sair { color: #fc8181 !important; margin-top: 30px; }
        .btn-sair:hover { background-color: rgba(229, 62, 62, 0.1) !important; color: #fc8181 !important; }

        /* ÁREA DE CONTEÚDO (Branca) */
        .main-content {
            flex: 1;
            padding: 40px;
            box-sizing: border-box;
            max-width: 100%; /* Evita que a tabela force a largura */
            overflow-x: hidden;
        }

        /* ========================================== */
        /* MÁGICA PARA TELEMÓVEIS (Menos de 768px)  */
        /* ========================================== */
        @@media (max-width: 768px) {
            .admin-wrapper {
                flex-direction: column; /* Coloca a barra lateral em cima e o conteúdo em baixo */
            }

            .sidebar {
                width: 100%;
                border-right: none;
                border-bottom: 4px solid #bba371;
            }

            .sidebar-header { padding: 20px; }
            .sidebar-header h2 { text-align: left; }
            .mobile-toggle { display: block; } /* Mostra o ícone no telemóvel */

            /* Oculta os links por padrão no telemóvel */
            .sidebar-menu {
                display: none;
                padding-bottom: 20px;
            }
            .sidebar-menu.aberto {
                display: flex; /* Mostra ao clicar */
            }

            .main-content {
                padding: 20px 15px; /* Menos margem no telemóvel */
            }
        }

        /* ========================================== */
        /* TABELAS RESPONSIVAS                      */
        /* ========================================== */
        .table-responsive {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }

        table { width: 100%; border-collapse: collapse; min-width: 600px; /* Força a tabela a ter largura mínima, ativando o scroll */ }
        th { background-color: #0d1326; color: white; padding: 15px; text-align: left; font-size: 14px; font-weight: 600; }
        td { padding: 15px; border-bottom: 1px solid #edf2f7; font-size: 14px; color: #4a5568; }
        tr:hover td { background-color: #f8fafc; }
    </style>
</head>
<body>

    <div class="admin-wrapper">
        
        <nav class="sidebar">
            <div class="sidebar-header">
                <h2>ADHEL GESTÃO</h2>
                <i class="fa-solid fa-bars mobile-toggle" onclick="toggleAdminMenu()"></i>
            </div>
            
           <div class="sidebar-menu" id="adminMenu">
                <a href="@Url.Action("Dashboard", "Painel", new { area = "Secretaria" })">
                    <i class="fa-solid fa-chart-pie"></i> Visão Geral
                </a>
                
                <a href="@Url.Action("Index", "Painel", new { area = "Secretaria" })">
                    <i class="fa-solid fa-users"></i> Controle de Membros
                </a>

                <a href="@Url.Action("RelatorioSantaCeia", "Painel", new { area = "Secretaria" })">
                    <i class="fa-solid fa-clipboard-list"></i> Relatório de Frequência
                </a>
                
                <a href="@Url.Action("Anuncios", "Painel", new { area = "Secretaria" })">
                    <i class="fa-solid fa-bullhorn"></i> Lançar Anúncios
                </a>
                <a href="@Url.Action("Eventos", "Painel", new { area = "Secretaria" })">
                    <i class="fa-regular fa-calendar-plus"></i> Agendar Eventos
                </a>
                
                <a href="@Url.Action("Logout", "Conta", new { area = "" })" class="btn-sair">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Sair do Painel
                </a>
            </div>
        </nav>

        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <script>
        function toggleAdminMenu() {
            var menu = document.getElementById("adminMenu");
            menu.classList.toggle("aberto");
        }
    </script>

</body>
</html>