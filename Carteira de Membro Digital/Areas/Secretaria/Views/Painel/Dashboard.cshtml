@{
    Layout = "~/Areas/Secretaria/Views/Shared/_LayoutSecretaria.cshtml";
}

<style>
    /* Grid Responsiva para os Cartões */
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    /* Estilo dos Cartões Interativos */
    .dash-card {
        background: #fff;
        padding: 25px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-left: 5px solid #0d1326;
        cursor: pointer;
    }

    .dash-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.1);
    }

    /* Cores Específicas das Bordas */
    .card-total { border-left-color: #3182ce; }
    .card-ativos { border-left-color: #38a169; }
    .card-pendentes { border-left-color: #dd6b20; }
    .card-eventos { border-left-color: #bba371; }

    .dash-info h3 { margin: 0; color: #718096; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
    .dash-info p { margin: 5px 0 0 0; color: #2d3748; font-size: 32px; font-weight: bold; }

    .dash-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    /* Cores de Fundo dos Ícones */
    .icon-total { background: #ebf8ff; color: #3182ce; }
    .icon-ativos { background: #c6f6d5; color: #38a169; }
    .icon-pendentes { background: #feebc8; color: #dd6b20; }
    .icon-eventos { background: #fffaf0; color: #bba371; }

    /* Estilo do Banner de Boas Vindas */
    .welcome-banner {
        background: linear-gradient(135deg, #0d1326 0%, #1a2544 100%);
        color: white;
        padding: 30px;
        border-radius: 12px;
        margin-bottom: 30px;
        border-left: 5px solid #bba371;
    }
    .welcome-banner h2 { margin: 0 0 10px 0; font-size: 24px; }
    .welcome-banner p { margin: 0; color: #cbd5e0; font-size: 15px; }
</style>

<div class="welcome-banner">
    <h2>Painel de Gestão de Membresia ADHEL</h2>
    <p>Aqui você tem uma visão geral e em tempo real do sistema da sua igreja.</p>
</div>

<div class="dashboard-grid">
    
    <div class="dash-card card-total">
        <div class="dash-info">
            <h3>Total Cadastrado</h3>
            <p>@ViewBag.TotalMembros</p>
        </div>
        <div class="dash-icon icon-total">
            <i class="fa-solid fa-users"></i>
        </div>
    </div>

    <div class="dash-card card-ativos">
        <div class="dash-info">
            <h3>Membros Ativos</h3>
            <p>@ViewBag.MembrosAtivos</p>
        </div>
        <div class="dash-icon icon-ativos">
            <i class="fa-solid fa-id-card-clip"></i>
        </div>
    </div>

    <div class="dash-card card-pendentes" onclick="window.location.href='@Url.Action("Index", "Painel")'">
        <div class="dash-info">
            <h3>Aguardando Aprovação</h3>
            <p>@ViewBag.CadastrosPendentes</p>
        </div>
        <div class="dash-icon icon-pendentes">
            <i class="fa-solid fa-user-clock"></i>
        </div>
    </div>

    <div class="dash-card card-eventos">
        <div class="dash-info">
            <h3>Eventos Futuros</h3>
            <p>@ViewBag.ProximosEventos</p>
        </div>
        <div class="dash-icon icon-eventos">
            <i class="fa-solid fa-calendar-check"></i>
        </div>
    </div>

    @if (ViewBag.MembrosEmAlerta > 0)
    {
        <div class="dash-card" style="border-left-color: #e53e3e; background: #fff5f5;" onclick="window.location.href='@Url.Action("RelatorioSantaCeia", "Painel")'">
            <div class="dash-info">
                <h3 style="color: #c53030;">Alerta Pastoral</h3>
                <p style="color: #9b2c2c;">@ViewBag.MembrosEmAlerta</p>
                <span style="font-size: 11px; color: #e53e3e; font-weight: bold;">Membros ausentes há 3 Ceias!</span>
            </div>
            <div class="dash-icon" style="background: #fed7d7; color: #e53e3e;">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
        </div>
    }

</div>