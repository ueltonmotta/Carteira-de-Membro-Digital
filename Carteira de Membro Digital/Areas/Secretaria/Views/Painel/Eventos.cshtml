@model List<CarteiraDeMembroDigital.Models.Evento>
@{
    Layout = "~/Areas/Secretaria/Views/Shared/_LayoutSecretaria.cshtml";
}

<style>
    /* Estilos do Formulário */
    .form-card {
        background: #fff;
        padding: 25px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        margin-bottom: 30px;
    }
    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; font-weight: 600; color: #4a5568; margin-bottom: 5px; font-size: 14px; }
    .form-control { width: 100%; padding: 12px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box; font-family: inherit; font-size: 14px; }
    
    .btn-submit { 
        background-color: #0d1326; 
        color: white; 
        border: none; 
        padding: 14px 20px; 
        border-radius: 6px; 
        font-weight: 600; 
        cursor: pointer; 
        width: 100%; 
        font-size: 15px; 
        margin-top: 10px;
    }
    .btn-submit:hover { background-color: #1a2544; }

    /* ========================================== */
    /* TABELA COM SCROLL PARA TELEMÓVEIS          */
    /* ========================================== */
    .table-responsive { 
        width: 100%; 
        overflow-x: auto; /* Permite arrastar para o lado */
        -webkit-overflow-scrolling: touch;
        background: #fff; 
        border-radius: 8px; 
        border: 1px solid #e2e8f0; 
    }
    
    /* O min-width força a tabela a não se esmagar */
    table { width: 100%; border-collapse: collapse; text-align: left; font-size: 14px; min-width: 600px; }
    th { background-color: #f8fafc; padding: 15px; color: #4a5568; font-weight: 700; border-bottom: 2px solid #e2e8f0; }
    td { padding: 15px; border-bottom: 1px solid #edf2f7; color: #2d3748; vertical-align: middle; }
    tr:hover { background-color: #f8fafc; }

    .btn-delete { color: #e53e3e; background: none; border: none; cursor: pointer; font-size: 18px; }
    .btn-delete:hover { color: #c53030; }
</style>

<div style="margin-bottom: 25px;">
    <h2 style="margin: 0; color: #0d1326;">Agenda da Igreja</h2>
    <p style="margin: 5px 0 0 0; color: #718096; font-size: 14px;">Programe os próximos cultos e eventos na linha do tempo dos membros.</p>
</div>

<div class="form-card">
    <h3 style="margin-top: 0; color: #0d1326; font-size: 16px; border-bottom: 1px solid #edf2f7; padding-bottom: 10px;">Agendar Novo Evento</h3>
    <form asp-action="CriarEvento" method="post">
        <div class="form-group">
            <label>Nome do Evento</label>
            <input type="text" name="Titulo" class="form-control" placeholder="Ex: Santa Ceia" required />
        </div>
        <div class="form-group">
            <label>Data e Hora</label>
            <input type="datetime-local" name="DataHora" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Local / Endereço</label>
            <input type="text" name="Local" class="form-control" placeholder="Ex: Templo Principal" required />
        </div>
        <div class="form-group">
            <label>Descrição Opcional</label>
            <textarea name="Descricao" class="form-control" rows="2" placeholder="Informações extras..."></textarea>
        </div>
        <button type="submit" class="btn-submit"><i class="fa-regular fa-calendar-plus"></i> Agendar Evento</button>
    </form>
</div>

<div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>Data e Hora</th>
                <th>Evento</th>
                <th>Local</th>
                <th style="text-align: center;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="4" style="text-align: center; color: #a0aec0; padding: 20px;">Nenhum evento agendado no momento.</td>
                </tr>
            }
            else
            {
                foreach (var ev in Model)
                {
                    <tr>
                        <td>
                            <strong style="color: #0d1326;">@ev.DataHora.ToString("dd/MM/yyyy")</strong><br />
                            <span style="color: #718096; font-size: 12px;">@ev.DataHora.ToString("HH:mm")h</span>
                        </td>
                        <td>
                            <strong>@ev.Titulo</strong><br />
                            <span style="color: #718096; font-size: 12px;">@ev.Descricao</span>
                        </td>
                        <td>@ev.Local</td>
                        <td style="text-align: center;">
                            <form asp-action="ExcluirEvento" method="post" onsubmit="return confirm('Tem certeza que deseja excluir este evento da agenda?');">
                                <input type="hidden" name="id" value="@ev.Id" />
                                <button type="submit" class="btn-delete" title="Excluir"><i class="fa-solid fa-trash-can"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>